[{"findings":[{"scannerType":"axe","url":"https://a11yhood.org/pr-preview/259/","html":"<strong>File not found</strong>","problemShort":"elements must meet minimum color contrast ratio thresholds","problemUrl":"https://dequeuniversity.com/rules/axe/4.11/color-contrast?application=playwright","ruleId":"color-contrast","solutionShort":"ensure the contrast between foreground and background colors meets wcag 2 aa minimum contrast ratio thresholds","solutionLong":"Fix any of the following:\n  Element has insufficient color contrast of 3.85 (foreground color: #797979, background color: #f1f1f1, font size: 12.0pt (16px), font weight: bold). Expected contrast ratio of 4.5:1"}],"issue":{"state":"open","id":4244982258,"nodeId":"I_kwDONoIDbM79BUny","url":"https://github.com/a11yhood/a11yhood.github.io/issues/260","title":"Accessibility issue: Elements must meet minimum color contrast ratio thresholds on /pr-preview/259/"},"pullRequest":{"id":"PR_kwDONoIDbM7RrOWQ","url":"https://github.com/a11yhood/a11yhood.github.io/pull/266","title":"[WIP] Fix accessibility issue: Ensure color contrast ratio thresholds are met"}},{"findings":[{"scannerType":"axe","url":"https://a11yhood.org/pr-preview/259/","html":"<html>","problemShort":"<html> element must have a lang attribute","problemUrl":"https://dequeuniversity.com/rules/axe/4.11/html-has-lang?application=playwright","ruleId":"html-has-lang","solutionShort":"ensure every html document has a lang attribute","solutionLong":"Fix any of the following:\n  The <html> element does not have a lang attribute"}],"issue":{"state":"open","id":4244982374,"nodeId":"I_kwDONoIDbM79BUpm","url":"https://github.com/a11yhood/a11yhood.github.io/issues/261","title":"Accessibility issue: <html> element must have a lang attribute on /pr-preview/259/"}},{"findings":[{"scannerType":"axe","url":"https://a11yhood.org/pr-preview/259/","html":"<html>","problemShort":"document should have one main landmark","problemUrl":"https://dequeuniversity.com/rules/axe/4.11/landmark-one-main?application=playwright","ruleId":"landmark-one-main","solutionShort":"ensure the document has a main landmark","solutionLong":"Fix all of the following:\n  Document does not have a main landmark"}],"issue":{"state":"open","id":4244982483,"nodeId":"I_kwDONoIDbM79BUrT","url":"https://github.com/a11yhood/a11yhood.github.io/issues/262","title":"Accessibility issue: Document should have one main landmark on /pr-preview/259/"},"pullRequest":{"id":"PR_kwDONoIDbM7RrOxw","url":"https://github.com/a11yhood/a11yhood.github.io/pull/268","title":"[WIP] Fix accessibility issue: add main landmark to document"}},{"findings":[{"scannerType":"axe","url":"https://a11yhood.org/pr-preview/259/","html":"<a href=\"https://help.github.com/pages/\">Read the full documentation</a>","problemShort":"links must be distinguishable without relying on color","problemUrl":"https://dequeuniversity.com/rules/axe/4.11/link-in-text-block?application=playwright","ruleId":"link-in-text-block","solutionShort":"ensure links are distinguished from surrounding text in a way that does not rely on color","solutionLong":"Fix any of the following:\n  The link has insufficient color contrast of 1.09:1 with the surrounding text. (Minimum contrast is 3:1, link text: #4183c4, surrounding text: #797979)\n  The link has no styling (such as underline) to distinguish it from the surrounding text"}],"issue":{"state":"open","id":4244982603,"nodeId":"I_kwDONoIDbM79BUtL","url":"https://github.com/a11yhood/a11yhood.github.io/issues/263","title":"Accessibility issue: Links must be distinguishable without relying on color on /pr-preview/259/"},"pullRequest":{"id":"PR_kwDONoIDbM7RrO4S","url":"https://github.com/a11yhood/a11yhood.github.io/pull/269","title":"[WIP] Fix accessibility issue: links must be distinguishable without relying on color"}},{"findings":[{"scannerType":"axe","url":"https://a11yhood.org/pr-preview/259/","html":"<a href=\"/\" class=\"logo logo-img-1x\">","problemShort":"links must have discernible text","problemUrl":"https://dequeuniversity.com/rules/axe/4.11/link-name?application=playwright","ruleId":"link-name","solutionShort":"ensure links have discernible text","solutionLong":"Fix all of the following:\n  Element is in tab order and does not have accessible text\n\nFix any of the following:\n  Element does not have text that is visible to screen readers\n  aria-label attribute does not exist or is empty\n  aria-labelledby attribute does not exist, references elements that do not exist or references elements that are empty\n  Element has no title attribute"}],"issue":{"state":"open","id":4244982723,"nodeId":"I_kwDONoIDbM79BUvD","url":"https://github.com/a11yhood/a11yhood.github.io/issues/264","title":"Accessibility issue: Links must have discernible text on /pr-preview/259/"},"pullRequest":{"id":"PR_kwDONoIDbM7RrO-O","url":"https://github.com/a11yhood/a11yhood.github.io/pull/270","title":"[WIP] Fix accessibility issue for links without discernible text"}},{"findings":[{"scannerType":"axe","url":"https://a11yhood.org/pr-preview/259/","html":"<h1>404</h1>","problemShort":"all page content should be contained by landmarks","problemUrl":"https://dequeuniversity.com/rules/axe/4.11/region?application=playwright","ruleId":"region","solutionShort":"ensure all page content is contained by landmarks","solutionLong":"Fix any of the following:\n  Some page content is not contained by landmarks"}],"issue":{"state":"open","id":4244982834,"nodeId":"I_kwDONoIDbM79BUwy","url":"https://github.com/a11yhood/a11yhood.github.io/issues/265","title":"Accessibility issue: All page content should be contained by landmarks on /pr-preview/259/"}}]
