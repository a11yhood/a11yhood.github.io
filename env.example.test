################################################################################
# a11yhood Frontend - TEST ENVIRONMENT CONFIGURATION EXAMPLE
#
# Copy relevant values to .env.local when running tests locally.
#
# Goal: run frontend tests against local/dev backend without requiring Supabase.
################################################################################

# Use dev auth mode so frontend issues dev tokens (dev-token-<role>)
VITE_DEV_MODE=true

# Default dev user fixture key: admin | moderator | user
VITE_DEV_USER=admin

# Backend API used by app runtime and integration tests
# Typical local backend:
VITE_API_URL=http://localhost:8002

# Optional logging verbosity in browser/tests
VITE_LOG_LEVEL=debug

# =========================================================================
# TEST BACKEND URL
# =========================================================================
#
# When set, enables backend-dependent accessibility and integration tests.
# Leave unset (default) to skip those tests when no backend is running.
#
# TEST_BACKEND_URL=http://localhost:8002

# =========================================================================
# FULL BACKEND TEST GATE (RESET AUTH)
# =========================================================================
#
# Full backend-capable suite runs perform a dev reset request before tests.
# The backend currently expects:
#   - Authorization: Bearer dev-token-admin
#   - X-Test-Run-Token: <token>
#
# Backend side (backend-test project only):
#   - DEV_TEST_AUTH_SECRET must be configured server-side
#   - Do NOT set DEV_TEST_AUTH_SECRET on production backend.
#
# Frontend/CI side:
#   - Set TEST_RUN_TOKEN in the environment that runs Vitest.
#   - In GitHub Actions, store as repository secret: TEST_RUN_TOKEN.
#
#   TEST_RUN_TOKEN should have the same value as DEV_TEST_AUTH_SECRET
#
# TEST_RUN_TOKEN=replace-with-test-run-token
